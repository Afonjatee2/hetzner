NODE_ENV=production
HOST=127.0.0.1
PORT=8082
MCP_PATH=/mcp
GATEWAY_NAME=mac-project-files
GATEWAY_PROFILE=local-files
PUBLIC_BASE_URL=https://mac-mcp.remoteconnector.uk
WORKSPACE_ROOT="/Users/your-user/Downloads"
WORKTREE_ROOT="/Users/your-user/Library/Application Support/MacProjectFiles/worktrees"
STATE_DIR="/Users/your-user/Library/Application Support/MacProjectFiles/state"
ARTIFACT_DIR="/Users/your-user/Library/Application Support/MacProjectFiles/artifacts"
DATABASE_URL="/Users/your-user/Library/Application Support/MacProjectFiles/state/app.db"
AUTH_MODE=first-party
OAUTH_OPERATOR_PASSWORD_HASH=
OAUTH_SIGNING_KEY_PATH="/Users/your-user/Library/Application Support/MacProjectFiles/state/oauth-signing-key.pem"
HANDOFF_OUTBOX_DIR="/Users/your-user/Library/Application Support/MacProjectFiles/outbox"
HANDOFF_SSH_TARGET=gptsync@167.233.75.192
HANDOFF_SSH_KEY_PATH=/Users/your-user/.config/mac-project-files/handoff_ed25519
HANDOFF_SSH_KNOWN_HOSTS_PATH=/Users/your-user/.config/mac-project-files/known_hosts
HANDOFF_MAX_BYTES=104857600
NODE_BINARY=/usr/local/bin/node

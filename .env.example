NODE_ENV=development
HOST=127.0.0.1
PORT=8081
MCP_PATH=/mcp
GATEWAY_NAME=hetzner-dev-workspace
GATEWAY_PROFILE=full
PUBLIC_BASE_URL=http://127.0.0.1:8081
WORKSPACE_ROOT=./fixtures/workspaces
WORKTREE_ROOT=./.state/worktrees
STATE_DIR=./.state
ARTIFACT_DIR=./.artifacts
DATABASE_URL=./.state/app.db
PROJECT_REGISTRY=./config/projects.yaml
TASK_DEFAULT_TIMEOUT_SECONDS=900
TASK_MAX_TIMEOUT_SECONDS=3600
TASK_MAX_OUTPUT_BYTES=10485760
TASK_DEFAULT_MEMORY=2g
TASK_DEFAULT_CPUS=2
TASK_DEFAULT_PIDS=256
TASK_NETWORK_DEFAULT=none
# Arbitrary host commands remain disabled on production gateways by default.
HOST_EXECUTION=disabled
# Enables only the fixed execute_plan coding-agent entry point.
AGENT_EXECUTION=disabled
HOST_PATH_PREPEND=
LOG_REDACTION_ENABLED=true
AUTH_MODE=development
# AUTH_MODE=oauth uses an external authorization server:
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_JWKS_URI=
# AUTH_MODE=first-party runs the embedded authorization server. Issuer, audience
# and the JWKS are all derived from PUBLIC_BASE_URL/MCP_PATH and the local signing
# key; OAUTH_ISSUER/OAUTH_AUDIENCE/OAUTH_JWKS_URI above are unused in this mode.
OAUTH_OPERATOR_PASSWORD_HASH=
OAUTH_SIGNING_KEY_PATH=./.state/oauth-signing-key.pem
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_DAYS=30
HANDOFF_INBOX_DIR=/var/lib/gpt-dev/handoffs/incoming
HANDOFF_MAX_BYTES=104857600
# GitHub fine-grained PAT (Contents: rw, Pull requests: rw) for create_pull_request and merge_pull_request tools
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com
# Persistent pnpm store mounted into task containers for offline installs
PNPM_STORE_DIR=/var/lib/gpt-dev/pnpm-store
# Docker network name for registry-only task networking (created by infra/scripts/setup-registry-network.sh)
REGISTRY_NETWORK_NAME=gptdev-registry

NODE_ENV=development
HOST=127.0.0.1
PORT=8081
MCP_PATH=/mcp
PUBLIC_BASE_URL=http://127.0.0.1:8081
WORKSPACE_ROOT=./fixtures/workspaces
WORKTREE_ROOT=./.state/worktrees
STATE_DIR=./.state
ARTIFACT_DIR=./.artifacts
DATABASE_URL=./.state/app.db
PROJECT_REGISTRY=./config/projects.yaml
TASK_DEFAULT_TIMEOUT_SECONDS=900
TASK_MAX_TIMEOUT_SECONDS=3600
TASK_MAX_OUTPUT_BYTES=10485760
TASK_DEFAULT_MEMORY=2g
TASK_DEFAULT_CPUS=2
TASK_DEFAULT_PIDS=256
TASK_NETWORK_DEFAULT=none
LOG_REDACTION_ENABLED=true
AUTH_MODE=development
# AUTH_MODE=oauth uses an external authorization server:
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_JWKS_URI=
# AUTH_MODE=first-party runs the embedded authorization server. Issuer, audience
# and the JWKS are all derived from PUBLIC_BASE_URL/MCP_PATH and the local signing
# key; OAUTH_ISSUER/OAUTH_AUDIENCE/OAUTH_JWKS_URI above are unused in this mode.
OAUTH_OPERATOR_PASSWORD_HASH=
OAUTH_SIGNING_KEY_PATH=./.state/oauth-signing-key.pem
OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
OAUTH_REFRESH_TOKEN_TTL_DAYS=30


{
  "name": "hetzner-dev-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "dev": "tsx watch apps/mcp-gateway/src/server.ts",
    "lint": "eslint .",
    "start": "node apps/mcp-gateway/dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.11.1",
    "fastify": "5.10.0",
    "jose": "6.2.3",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.0.14",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.39.1",
    "playwright": "1.61.1",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.37.0",
    "vitest": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
